VITE_FS_BASE_URL=http://localhost:8000
VITE_FS_USERNAME=your_username
VITE_FS_PASSWORD=your_password
VITE_FS_MARKET_ID=15
VITE_FS_AUTO_AUTH=true

# Shared agent cache + Exa/Claude proxies — browser uses /agent-cache (Vite proxy); server on :8787
VITE_AGENT_CACHE_URL=/agent-cache
VITE_AGENT_CACHE_TARGET=http://localhost:8787

# Shared gate for the agent API (server + static site must match). Generate: openssl rand -hex 32
AGENT_API_SECRET=
VITE_AGENT_API_SECRET=

# Server-only (app/.env.local or Render cache web service — not VITE_*)
EXA_API_KEY=
ANTHROPIC_API_KEY=

# Render Postgres (server reads DB_URL or fields below)
DB_URL=
DB_HOSTNAME=""
DB_PORT=""
DB_DATABASE=""
DB_USERNAME=""
DB_PASSWORD=""
DB_URL=""